# ── Python ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
build/
dist/
*.egg-info/
.eggs/
*.egg
pip-wheel-metadata/
*.whl

# ── Virtual environments ─────────────────────────────────────
venv/
.venv/
env/
ENV/

# ── Data files (large; tracked separately in DVC or S3) ─────
data/*.parquet
data/*.csv
data/*.json
!data/.gitkeep

# ── Model artefacts ──────────────────────────────────────────
models/*.pth
models/*.pkl
models/*.pt
models/*.onnx
models/vae_meta.json
models/gnn_meta.json

# ── Reports / generated outputs ──────────────────────────────
reports/*.png
reports/*.csv
reports/*.json
!reports/__init__.py
!reports/confusion_matrix.py

# ── Logs ─────────────────────────────────────────────────────
logs/
*.log

# ── IDE ──────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Testing ──────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/

# ── Jupyter ──────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Environment ──────────────────────────────────────────────
.env
.env.*
*.env
